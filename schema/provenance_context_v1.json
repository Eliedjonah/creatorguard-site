{
  "@context": {
    "@version": 1.1,
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "sec": "https://w3id.org/security#",
    "cg": "https://creatorguard.tech/vocab#",
    "CreatorGuardAuthorizationCredential": "cg:CreatorGuardAuthorizationCredential",
    "contentId": {
      "@id": "cg:contentId",
      "@type": "xsd:string"
    },
    "provenanceContinuityId": {
      "@id": "cg:provenanceContinuityId",
      "@type": "xsd:string"
    },
    "contentFingerprint": {
      "@id": "cg:contentFingerprint",
      "@type": "@id",
      "@context": {
        "sha256": {
          "@id": "cg:sha256",
          "@type": "xsd:string"
        },
        "algorithm": {
          "@id": "cg:algorithm",
          "@type": "xsd:string"
        }
      }
    },
    "authorizationState": {
      "@id": "cg:authorizationState",
      "@type": "@id",
      "@context": {
        "ai_training": {
          "@id": "cg:aiTraining",
          "@type": "@id",
          "@context": {
            "authorized": {
              "@id": "cg:authorized",
              "@type": "xsd:boolean"
            },
            "basis": {
              "@id": "cg:basis",
              "@type": "xsd:string"
            },
            "note": {
              "@id": "cg:note",
              "@type": "xsd:string"
            }
          }
        },
        "commercial_reuse": {
          "@id": "cg:commercialReuse",
          "@type": "@id",
          "@context": {
