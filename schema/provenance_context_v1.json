              "@id": "cg:permitted",
              "@type": "xsd:boolean"
            },
            "license_type": {
              "@id": "cg:licenseType",
              "@type": "xsd:string"
            }
          }
        },
        "attribution": {
          "@id": "cg:attribution",
          "@type": "@id",
          "@context": {
            "required": {
              "@id": "cg:required",
              "@type": "xsd:boolean"
            },
            "format": {
              "@id": "cg:format",
              "@type": "xsd:string"
            }
          }
        },
        "jurisdictional": {
          "@id": "cg:jurisdictional",
          "@type": "@id",
          "@context": {
            "jurisdiction": {
              "@id": "cg:jurisdiction",
              "@type": "xsd:string"
            },
            "frameworks": {
              "@id": "cg:frameworks",
              "@container": "@set",
              "@type": "xsd:string"
            },
            "restricted": {
              "@id": "cg:restricted",
              "@type": "xsd:boolean"
            }
          }
        },
