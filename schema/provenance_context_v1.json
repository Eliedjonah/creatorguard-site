            "disclosure_required": {
              "@id": "cg:disclosureRequired",
              "@type": "xsd:boolean"
            }
          }
        },
        "derivatives": {
          "@id": "cg:derivatives",
          "@type": "@id",
          "@context": {
            "permitted": {
              "@id": "cg:derivativesPermitted",
              "@type": "xsd:boolean"
            }
          }
        }
